# Site ve uygulama için iletişim bilgileri.
# Bu dosyayı .env.local olarak kopyalayıp doldurun.
# Vercel'de Environment Variables olarak da ekleyebilirsiniz.

NEXT_PUBLIC_ADDRESS=Örnek Cad. No: 1, Üsküdar / İstanbul
NEXT_PUBLIC_PHONE=+90 (216) 000 00 00
NEXT_PUBLIC_EMAIL=info@moladaofis.com
NEXT_PUBLIC_WHATSAPP=905321234567
NEXT_PUBLIC_MAP_URL=https://www.google.com/maps?q=...

# Supabase: Session pooler (Netlify / serverless için)
# DATABASE_URL=postgresql://postgres.PROJE_REF:SIFRE@aws-....pooler.supabase.com:5432/postgres?sslmode=require
# Doğrudan bağlantı — sadece prisma migrate / prisma db * için (lokal)
# DIRECT_URL=postgresql://postgres:SIFRE@db.PROJE_REF.supabase.co:5432/postgres?sslmode=require
DATABASE_URL=
DIRECT_URL=

# JWT imzası (local/production için secret koyun)
AUTH_SECRET="change-me-please"

# Admin panel giriş (admin kullanıcısı ayrı)
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-me-please"

# WiFi bilgisi (router tarafında aynı SSID kullanılır)
WIFI_SSID="MoladaWiFi"
