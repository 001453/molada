# Site ve uygulama için iletişim bilgileri.
# Bu dosyayı .env.local olarak kopyalayıp doldurun.
# Netlify / Vercel: Environment Variables.

NEXT_PUBLIC_ADDRESS=Örnek Cad. No: 1, Üsküdar / İstanbul
NEXT_PUBLIC_PHONE=+90 (216) 000 00 00
NEXT_PUBLIC_EMAIL=info@moladaofis.com
NEXT_PUBLIC_WHATSAPP=905321234567
NEXT_PUBLIC_MAP_URL=https://www.google.com/maps?q=...

# --- Supabase (API üzerinden DB — Netlify için önerilen yol) ---
# Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://PROJE_REF.supabase.co
# Sunucu tarafı (API routes) — asla tarayıcıya / frontend'e verme:
SUPABASE_SERVICE_ROLE_KEY=

# --- Prisma (sadece lokal migrate / prisma generate) ---
# Netlify build: prisma generate için geçerli biçimde yer tutucu da kullanılabilir.
# DATABASE_URL=postgresql://postgres:...@db.PROJE_REF.supabase.co:5432/postgres?sslmode=require
# DIRECT_URL=aynı veya session pooler
DATABASE_URL=
DIRECT_URL=

# JWT imzası (local/production için secret koyun)
AUTH_SECRET="change-me-please"

# Admin panel giriş (admin kullanıcısı ayrı)
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-me-please"

# WiFi bilgisi (router tarafında aynı SSID kullanılır)
WIFI_SSID="MoladaWiFi"
